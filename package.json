{
  "name": "folio",
  "version": "0.1.0",
  "description": "A magical ebook library manager",
  "main": "src/main/main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "build:mac": "electron-builder --mac"
  },
  "author": "Tash",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "epub2": "^3.0.2",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.tash.folio",
    "productName": "Tome",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
